{
  "name": "pentest-automation-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"next dev\" \"tsx watch server/index.ts\" \"tsx watch server/worker.ts\"",
    "dev:app": "next dev",
    "dev:server": "tsx watch server/index.ts",
    "dev:worker": "tsx watch server/worker.ts",
    "build": "next build && tsup server/index.ts server/worker.ts --format esm --out-dir dist --clean --splitting false",
    "start:web": "next start -H 0.0.0.0 -p 3000",
    "start:api": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "start": "concurrently -k \"cross-env NODE_ENV=production next start\" \"cross-env NODE_ENV=production node dist/index.js\" \"cross-env NODE_ENV=production node dist/worker.js\"",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.10",
    "cookie": "^1.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.475.0",
    "next": "^15.2.0",
    "pdfkit": "^0.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^22.13.9",
    "@types/pdfkit": "^0.17.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "postcss": "^8.5.3",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
